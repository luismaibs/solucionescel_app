# Supabase Configuration (example)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_VERIFY_SSL=true

# Session
SESSION_LIFETIME=2592000

# Tenant
TENANT_ID_DEFAULT=1

# Environment
APP_ENV=development
APP_DEBUG=false
